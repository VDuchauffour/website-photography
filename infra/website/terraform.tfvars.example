# Copy to terraform.tfvars and fill in your values
# >>> NEVER commit terraform.tfvars — it contains secrets <<<

# Scaleway API credentials (same as storage module)
scw_access_key = "SCW..."
scw_secret_key = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
scw_project_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
scw_user_id    = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Website bucket
region              = "fr-par"
website_bucket_name = "site-vincentduchauffour"

# Domain managed in Scaleway Domains & DNS
website_domain = "vincentduchauffour.com"
